# --- Option A: OpenAI directly ---
OPENAI_API_KEY=sk-...
# Optional overrides:
# REALTIME_MODEL=gpt-realtime-2.1
# For ~3x cheaper sessions, A/B this and judge the Tagalog with your own ears:
# REALTIME_MODEL=gpt-realtime-2.1-mini
# FEEDBACK_MODEL=gpt-4o-mini

# --- Option B: Azure AI Foundry ---
# Setting AZURE_OPENAI_ENDPOINT switches all calls to your Foundry resource.
# Model vars then take your *deployment names*, and the resource needs
# deployments of: a realtime model, a transcribe model, and a chat model
# for the post-session feedback report.
# FOUNDRY_API_KEY=...            (alias for OPENAI_API_KEY)
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.services.ai.azure.com
# REALTIME_MODEL=gpt-realtime-2
# TRANSCRIBE_MODEL=gpt-4o-transcribe
# FEEDBACK_MODEL=gpt-4o-mini

# Set on public deployments to require a password (HTTP Basic Auth, any username).
# Leave unset for local use.
# APP_PASSWORD=choose-a-strong-password
